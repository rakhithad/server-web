
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique 
  passwordHash     String   
  isEmailVerified  Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profile         Profile?

}

model Profile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique 
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  biography       String?  @db.Text
  linkedInUrl     String?
  profileImageUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  degrees        Degree[]
  certifications Certification[]
  licences       Licence[]
  courses        Course[]
  employments    EmploymentHistory[]

}

model Degree {
  id             Int      @id @default(autoincrement())
  profileId      Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title          String
  institution    String
  universityUrl  String   
  completionDate DateTime @db.Date
}

model Certification {
  id             Int      @id @default(autoincrement())
  profileId      Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title          String
  awardingBody   String
  courseUrl      String   
  completionDate DateTime @db.Date
}

model Licence {
  id             Int      @id @default(autoincrement())
  profileId      Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title          String
  awardingBody   String
  licenceUrl     String   
  completionDate DateTime @db.Date
}

model Course {
  id             Int      @id @default(autoincrement())
  profileId      Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title          String
  provider       String
  courseUrl      String   
  completionDate DateTime @db.Date
}

model EmploymentHistory {
  id             Int      @id @default(autoincrement())
  profileId      Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  jobTitle       String
  company        String
  startDate      DateTime @db.Date
  endDate        DateTime? @db.Date 
}